#!/usr/bin/python3

import argparse
import json
import os
import subprocess
import sys
import time

sys.path.append(os.getenv('HOME') + '/lib')

import libdpy
import liblayout

def get_active_window_geometry():
    """Return (window_id, x, y, width, height) for the active window."""
    out = subprocess.check_output(
        ['xdotool', 'getactivewindow', 'getwindowgeometry', '--shell']
    ).decode()
    vals = {}
    for line in out.splitlines():
        k, _, v = line.partition('=')
        vals[k] = int(v)
    return vals['WINDOW'], vals['X'], vals['Y'], vals['WIDTH'], vals['HEIGHT']


def move_to_adjacent_screen(adjacent_screen):
    x = int(adjacent_screen['x_offset'] + (adjacent_screen['width'] / 2))
    y = int(adjacent_screen['y_offset'] + (adjacent_screen['height'] / 2))
    subprocess.run(['xdotool', 'mousemove', str(x), str(y)], check=True)
    # subprocess.run(['focus-active-window'], check=True)


def wait_for_sethead(win_x, win_y, timeout=2.0):
    """Poll until the active window moves from its pre-SetHead position."""
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        _, post_x, post_y, _, _ = get_active_window_geometry()
        if post_x != win_x or post_y != win_y:
            return post_x, post_y
        time.sleep(0.02)
    return win_x, win_y


def make_logger(debug):
    logfile = os.path.expanduser("~/.log/screen-navigation-move-window.log")

    def dbg(msg):
        line = f"DEBUG: {msg}\n"
        if debug:
            sys.stderr.write(line)
        with open(logfile, 'a') as f:
            f.write(line)

    return dbg


def compute_target_geometry(win_x, win_y, win_w, win_h, src, dst, dbg):
    """
    Calculate where the window should be placed on the destination screen.

    All four edges are mapped proportionally: each edge's position as a
    fraction of the source screen dimension is preserved on the destination.
    This means both position and size scale with the destination screen.
    """
    left_frac   = (win_x - src['x_offset']) / src['width']
    top_frac    = (win_y - src['y_offset']) / src['height']
    right_frac  = (win_x + win_w - src['x_offset']) / src['width']
    bottom_frac = (win_y + win_h - src['y_offset']) / src['height']
    dbg(f"left={left_frac:.3f} right={right_frac:.3f} "
        f"top={top_frac:.3f} bottom={bottom_frac:.3f}")

    new_x = int(dst['x_offset'] + left_frac  * dst['width'])
    new_y = int(dst['y_offset'] + top_frac   * dst['height'])
    new_w = int((right_frac  - left_frac)  * dst['width'])
    new_h = int((bottom_frac - top_frac)   * dst['height'])
    dbg(f"target geometry: x={new_x} y={new_y} w={new_w} h={new_h}")
    return new_x, new_y, new_w, new_h


def reposition_window(win_id, win_x, win_y, new_x, new_y, new_w, new_h, dbg):
    """Move and resize the window to its target geometry."""
    dbg(f"running: xdotool windowmove {win_id} {new_x} {new_y}")
    subprocess.run(
        ['xdotool', 'windowmove', str(win_id), str(new_x), str(new_y)],
        check=True
    )
    dbg(f"running: xdotool windowsize {win_id} {new_w} {new_h}")
    subprocess.run(
        ['xdotool', 'windowsize', str(win_id), str(new_w), str(new_h)],
        check=True
    )
    _, final_x, final_y, _, _ = get_active_window_geometry()
    dbg(f"window position after reposition: x={final_x} y={final_y}")


def warp_mouse_to_window_centre(new_x, new_y, win_w, win_h, dbg):
    cx, cy = int(new_x + win_w / 2), int(new_y + win_h / 2)
    dbg(f"warping mouse to ({cx}, {cy})")
    subprocess.run(['xdotool', 'mousemove', str(cx), str(cy)], check=True)


def is_window_sticky(win_id):
    """Return True if the window has _NET_WM_STATE_STICKY set."""
    out = subprocess.check_output(
        ['xprop', '-id', str(win_id), '_NET_WM_STATE']
    ).decode()
    return '_NET_WM_STATE_STICKY' in out


def adjust_sticky_for_head(win_id, src, dst, dbg):
    """
    Stick the window when moving away from primary; unstick when returning to
    primary.  Uses wmctrl with the window ID directly to avoid focus races
    that affect fluxbox-remote StickWindow.
    """
    src_primary = bool(src.get('primary'))
    dst_primary = bool(dst.get('primary'))

    if src_primary == dst_primary:
        dbg("src and dst have same primary status; not changing sticky state")
        return

    want_sticky = not dst_primary
    currently_sticky = is_window_sticky(win_id)
    dbg(f"src_primary={src_primary} dst_primary={dst_primary} "
        f"want_sticky={want_sticky} currently_sticky={currently_sticky}")

    if want_sticky != currently_sticky:
        action = 'add' if want_sticky else 'remove'
        dbg(f"running: wmctrl -i -r {win_id} -b {action},sticky")
        subprocess.run(
            ['wmctrl', '-i', '-r', str(win_id), '-b', f'{action},sticky'],
            check=True
        )


def move_window_to_adjacent_screen(adjacent_screen, debug=False):
    dbg = make_logger(debug)

    set_head_cmd = adjacent_screen.get('SetHead')
    if not set_head_cmd:
        sys.stderr.write("Error: No SetHead value available for adjacent screen\n")
        sys.exit(1)

    win_id, win_x, win_y, win_w, win_h = get_active_window_geometry()
    dbg(f"active window: id={win_id} x={win_x} y={win_y} w={win_w} h={win_h}")

    src = libdpy.get_screen(int(win_x + win_w / 2), use_cache=True)
    dbg(f"source screen: {src['name']} x_offset={src['x_offset']} y_offset={src['y_offset']} w={src['width']} h={src['height']}")

    new_x, new_y, new_w, new_h = compute_target_geometry(win_x, win_y, win_w, win_h, src, adjacent_screen, dbg)

    dbg(f"running: fluxbox-remote '{set_head_cmd}'")
    subprocess.run(['fluxbox-remote', set_head_cmd], check=True)

    post_x, post_y = wait_for_sethead(win_x, win_y)
    dbg(f"window position after SetHead: x={post_x} y={post_y}")

    reposition_window(win_id, win_x, win_y, new_x, new_y, new_w, new_h, dbg)
    adjust_sticky_for_head(win_id, src, adjacent_screen, dbg)
    warp_mouse_to_window_centre(new_x, new_y, new_w, new_h, dbg)


def get_layout_file(args):
    if args.layout:
        return args.layout
    try:
        layout = subprocess.check_output(
            [os.path.join(os.path.dirname(os.path.realpath(__file__)), 'get-layout')]
        ).decode().strip()
        return layout
    except (subprocess.SubprocessError, FileNotFoundError):
        sys.stderr.write("Error: Could not determine layout. Please specify with --layout\n")
        sys.exit(1)


def get_window_centre_x():
    try:
        _, win_x, _, win_w, _ = get_active_window_geometry()
        return win_x + win_w / 2
    except Exception as e:
        sys.stderr.write(f"Error getting window geometry: {str(e)}\n")
        sys.exit(1)


def main():
    parser = argparse.ArgumentParser(description='Get the adjacent screen (left or right) from the current screen')
    parser.add_argument('direction', nargs='?', choices=['left', 'right'], help='Direction to look for adjacent screen')
    parser.add_argument('--head', '-H', type=int, metavar='N', help='Target a specific screen by physical position (1=leftmost, 2=next, etc.)')
    parser.add_argument('--layout', '-l', dest='layout', help='Layout name or path (default: use get-layout script)')
    parser.add_argument('--json', '-j', action='store_true', help='Output in JSON format')
    parser.add_argument('--move', '-m', action='store_true', help='Move mouse cursor to the adjacent screen')
    parser.add_argument('--move-window', '-w', action='store_true', help='Move current window to the target screen')
    parser.add_argument('--debug', '-d', action='store_true', help='Print debug info to stderr')
    parser.add_argument('--use-xrandr-cache', '-c', action='store_true', help='Use cached XRandr data if available')
    parser.add_argument('--format', '-f',
                        choices=['name', 'assignment', 'head', 'num', 'width', 'height', 'x_offset', 'y_offset', 'full'],
                        default='name',
                        help='Output format (default: name)')
    args = parser.parse_args()

    if args.head is None and args.direction is None:
        parser.error("either direction or --head is required")
    if args.head is not None and args.direction is not None:
        parser.error("direction and --head are mutually exclusive")

    layout_file = get_layout_file(args)

    if args.head is not None:
        try:
            target_screen = liblayout.get_screen_by_position(args.head, layout_file, use_cache=args.use_xrandr_cache)
        except Exception as e:
            sys.stderr.write(f"Error: {str(e)}\n")
            sys.exit(1)
        if target_screen is None:
            sys.stderr.write(f"No screen at position {args.head} (out of range)\n")
            sys.exit(1)
        if args.move_window:
            move_window_to_adjacent_screen(target_screen, debug=args.debug)
        elif args.move:
            move_to_adjacent_screen(target_screen)
        elif args.json:
            print(json.dumps(target_screen, indent=2))
        else:
            print(target_screen.get('name', target_screen.get('assignment', '')))
        return

    # When moving a window, use its centre to determine the current screen
    # rather than the mouse position, as they may differ
    current_x = get_window_centre_x() if args.move_window else None

    try:
        adjacent_screen = liblayout.get_adjacent_screen(
            args.direction, layout_file,
            use_cache=args.use_xrandr_cache,
            current_x=current_x,
        )
    except Exception as e:
        sys.stderr.write(f"Error: {str(e)}\n")
        sys.exit(1)

    if adjacent_screen is None:
        sys.stderr.write(f"No {args.direction} screen found from current position\n")
        sys.exit(1)

    if args.move:
        move_to_adjacent_screen(adjacent_screen)
        return

    if args.move_window:
        move_window_to_adjacent_screen(adjacent_screen, debug=args.debug)
        return

    if args.json:
        print(json.dumps(adjacent_screen, indent=2))
        return

    if args.format == 'full':
        for key, value in adjacent_screen.items():
            print(f"{key}={value}")
        return

    if args.format in adjacent_screen:
        print(adjacent_screen[args.format])
    elif args.format == 'name' and 'assignment' in adjacent_screen:
        print(adjacent_screen['assignment'])
    elif args.format == 'assignment' and 'name' in adjacent_screen:
        print(adjacent_screen['name'])
    else:
        sys.stderr.write(f"Error: Attribute '{args.format}' not found in screen data\n")
        sys.exit(1)


if __name__ == "__main__":
    main()
