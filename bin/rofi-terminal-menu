#!/bin/bash
#
# Rofi-based terminal/monitor menu, replacing the fluxbox 'terminals' key mode.
#
# Presents terminal and system monitor actions in a rofi menu and executes
# the selected action directly.
#
# Invoked from the fluxbox keys file:
#   Mod4 t :Exec rofi-terminal-menu

# shellcheck source=../lib/librofi.sh
source "$(dirname "$0")/../lib/librofi.sh"

# Parallel arrays: LABELS[i] is displayed, CMDS[i] is executed.
LABELS=()
CMDS=()

add() { LABELS+=("$1"); CMDS+=("$2"); }

add "t: terminal"           "xterm-window"
add "T: toggle light/dark"  "set-colour-theme --toggle"
add "b: btop"               "fluxbox-focus-or-launch --toggle btop top-term btop"
add "h: htop"               "fluxbox-focus-or-launch --toggle 'htop' top-term htop"
add "n: nethogs"            "fluxbox-focus-or-launch --toggle 'sudo nethogs .*' top-term sudo nethogs \$(gw-dev)"
add "i: iotop"              "fluxbox-focus-or-launch --toggle 'sudo iotop' top-term sudo iotop"
add "g: iftop gateway"      "fluxbox-focus-or-launch --toggle 'sudo iftop .*' top-term sudo iftop -i \$(gw-dev)"
add "p: powertop"           "fluxbox-focus-or-launch --toggle 'sudo powertop' top-term sudo powertop"
add "v: nvtop"              "fluxbox-focus-or-launch --toggle 'nvtop' top-term nvtop"
add "a: amdgpu_top"         "fluxbox-focus-or-launch --toggle 'amdgpu_top' top-term amdgpu_top"
add "s: lnav-system"        "fluxbox-focus-or-launch --toggle -r 'lnav-system' top-term lnav-system"
add "x: rxx"                "run-with-local-X-display top-term rxx"

chosen=$(printf '%s\n' "${LABELS[@]}" | rofi_prefix_filter | rofi -dmenu -p "terminal" \
    -matching prefix \
    -auto-select \
    -theme-str "$ROFI_THEME_STR" \
    -theme-str 'window {width: 800px;}' \
    -theme-str 'listview {lines: 12;}')

[[ -z "$chosen" ]] && exit 0

# rofi_prefix_filter returns the prefix (text before ':'), so match against
# the prefix of each label rather than the full label.
for i in "${!LABELS[@]}"; do
    if [[ "${LABELS[$i]%%:*}" == "$chosen" ]]; then
        cmd="${CMDS[$i]}"
        [[ -z "$cmd" ]] && exit 0
        eval "$cmd"
        exit 0
    fi
done
